<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="auth.LoginController"
           stylesheets="@auth.css"
           styleClass="auth-root">
           

    <HBox styleClass="auth-shell" maxWidth="920" maxHeight="560">

        <VBox styleClass="brand-panel" alignment="CENTER_LEFT" spacing="18">
            <Label text="⚡" styleClass="brand-icon"/>
            <Label text="GYMBRUT" styleClass="brand-title"/>
            <Label text="Gym Management System" styleClass="brand-subtitle"/>

            <Label text="Kelola membership, payment, dan data member dalam satu dashboard."
                   wrapText="true"
                   styleClass="brand-desc"/>

            <VBox spacing="8" styleClass="feature-list">
                <Label text="✓ Admin &amp; Member Login" styleClass="feature-item"/>
                <Label text="✓ Membership Management" styleClass="feature-item"/>
                <Label text="✓ Payment Tracking" styleClass="feature-item"/>
            </VBox>
        </VBox>

        <VBox styleClass="login-panel" alignment="CENTER" spacing="18">

            <VBox alignment="CENTER" spacing="6">
                <Label text="Welcome Back" styleClass="login-title"/>
                <Label text="Masuk ke akun GYMBRUT kamu" styleClass="login-subtitle"/>
            </VBox>

            <VBox spacing="10" maxWidth="330">
                <Label text="Email" styleClass="field-label"/>
                <TextField fx:id="emailField"
                           promptText="admin@gym.com"
                           styleClass="input"/>

                <Label text="Password" styleClass="field-label"/>
                <PasswordField fx:id="passwordField"
                               promptText="Masukkan password"
                               styleClass="input"/>

                <Button text="Login"
                        onAction="#handleLogin"
                        styleClass="btn-primary"
                        maxWidth="Infinity"/>

                <Button text="Daftar akun member"
                        onAction="#goToRegister"
                        styleClass="btn-link"
                        maxWidth="Infinity"/>

                <Label fx:id="messageLabel"
                       styleClass="error-text"
                       wrapText="true"/>
            </VBox>

            <Label text="Demo: admin@gym.com / admin123"
                   styleClass="hint-text"/>

        </VBox>

    </HBox>
</StackPane>