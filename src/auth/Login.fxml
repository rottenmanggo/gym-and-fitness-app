<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="auth.LoginController"
           stylesheets="@auth.css"
           prefWidth="1100"
           prefHeight="720"
           styleClass="auth-page">

    <VBox styleClass="auth-card" spacing="16" alignment="CENTER">

        <!-- Logo pakai emoji -->
        <Label text="🏋" styleClass="auth-logo"/>

        <!-- Judul & subtitle -->
        <Label text="GYMBRUT" styleClass="auth-title"/>
        <Label text="Login ke sistem fitness &amp; gym management"
        alignment="CENTER"
               wrapText="true"
               maxWidth="380"
               styleClass="auth-subtitle"/>

        <!-- Alert -->
        <Label fx:id="alertLabel"
               text=""
               wrapText="true"
               maxWidth="380"
               visible="false"
               managed="false"
               styleClass="auth-alert"/>

        <!-- Form -->
        <VBox styleClass="auth-form" spacing="12" alignment="CENTER">
            <HBox alignment="CENTER_LEFT" spacing="10" maxWidth="320">
                <Label text="📧" styleClass="field-icon"/>
                <TextField fx:id="emailField"
                           promptText="Masukkan email"
                           styleClass="form-control"
                           prefWidth="280"/>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="10" maxWidth="320">
                <Label text="🔒" styleClass="field-icon"/>
                <PasswordField fx:id="passwordField"
                               promptText="Masukkan password"
                               styleClass="form-control"
                               prefWidth="280"/>
            </HBox>

            <Button text="Login"
                    onAction="#handleLogin"
                    styleClass="gradient-btn"
                    prefWidth="220"
                    minHeight="44"/>
        </VBox>

        <!-- Link register -->
        <Hyperlink text="Belum punya akun? Register sekarang"
                   onAction="#handleRegisterLink"
                   styleClass="auth-link"/>
    </VBox>
</StackPane>