<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="auth.LoginController"
           stylesheets="@auth.css"
           prefWidth="1100"
           prefHeight="720"
           styleClass="auth-page">

    <VBox styleClass="auth-card"
      spacing="16"
      alignment="CENTER"
      maxWidth="460"
      maxHeight="520">

        <!-- Logo -->
<ImageView fitWidth="86"
           fitHeight="86"   
           preserveRatio="true"
           styleClass="auth-logo-img">
    <image>
        <Image url="@../assets/image/logo-gymbrut.png"/>
    </image>
</ImageView>

        <!-- Judul & subtitle -->
        <Label text="GYMBRUT" styleClass="auth-title"/>
        <Label text="Login ke sistem fitness &amp; gym management"
        alignment="CENTER"
               wrapText="true"
               maxWidth="380"
               styleClass="auth-subtitle"/>

        <!-- Alert -->
        <Label fx:id="alertLabel"
       text=""
       alignment="CENTER"
       wrapText="true"
       maxWidth="380"
       visible="false"
       managed="false"
       styleClass="auth-alert"/>

        <!-- Form -->
        <VBox styleClass="auth-form" spacing="12" alignment="CENTER">
            <HBox alignment="CENTER_LEFT" spacing="10" maxWidth="320">
                <Label text="📧" styleClass="field-icon"/>
                <TextField fx:id="emailField"
           promptText="Masukkan email"
           onAction="#focusPassword"
           styleClass="form-control"
           prefWidth="280"/>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="10" maxWidth="320">
                <Label text="🔒" styleClass="field-icon"/>
                <PasswordField fx:id="passwordField"
               promptText="Masukkan password"
               onAction="#handleLogin"
               styleClass="form-control"
               prefWidth="280"/>
            </HBox>

            <Button text="Login"
                    onAction="#handleLogin"
                    styleClass="gradient-btn"
                    prefWidth="220"
                    minHeight="44"/>
        </VBox>

        <!-- Link register -->
        <Button text="Belum punya akun? Register sekarang"
                onAction="#handleRegisterLink"
                styleClass="auth-link-btn"/>
    </VBox>
</StackPane>