<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="auth.RegisterController"
           stylesheets="@auth.css"
           styleClass="auth-page">

    <VBox alignment="CENTER"
      spacing="10"
      maxWidth="520"
      maxHeight="660"
      styleClass="auth-card register-card">

        <!-- Logo -->
        <ImageView fitWidth="74"
           fitHeight="74"
           preserveRatio="true"
           styleClass="auth-logo-img">
    <image>
        <Image url="@../assets/image/logo-gymbrut.png"/>
    </image>
</ImageView>

        <!-- Title -->
        <Label text="Create Account" styleClass="auth-title"/>
        <Label text="Daftar akun member Gym &amp; Fitness" styleClass="auth-subtitle"/>

        <!-- Form -->
        <GridPane hgap="12" vgap="10" maxWidth="390">
            <padding>
                <Insets top="12" right="0" bottom="8" left="0"/>
            </padding>

           <TextField fx:id="nameField"
           promptText="Nama Lengkap"
           onAction="#focusEmail"
           GridPane.rowIndex="0"
           GridPane.columnIndex="0"
           GridPane.columnSpan="2"
           styleClass="auth-input"/>

<TextField fx:id="emailField"
           promptText="Email"
           onAction="#focusPassword"
           GridPane.rowIndex="1"
           GridPane.columnIndex="0"
           GridPane.columnSpan="2"
           styleClass="auth-input"/>

<PasswordField fx:id="passwordField"
               promptText="Password"
               onAction="#focusPhone"
               GridPane.rowIndex="2"
               GridPane.columnIndex="0"
               GridPane.columnSpan="2"
               styleClass="auth-input"/>

<TextField fx:id="phoneField"
           promptText="No HP"
           onAction="#focusGender"
           GridPane.rowIndex="3"
           GridPane.columnIndex="0"
           GridPane.columnSpan="2"
           styleClass="auth-input"/>

<ComboBox fx:id="genderBox"
          promptText="Gender"
          onAction="#focusAge"
          GridPane.rowIndex="4"
          GridPane.columnIndex="0"
          styleClass="auth-input"
          prefWidth="190"/>

<TextField fx:id="ageField"
           promptText="Umur"
           onAction="#focusHeight"
           GridPane.rowIndex="4"
           GridPane.columnIndex="1"
           styleClass="auth-input"
           prefWidth="190"/>

<TextField fx:id="heightField"
           promptText="Tinggi (cm)"
           onAction="#focusWeight"
           GridPane.rowIndex="5"
           GridPane.columnIndex="0"
           styleClass="auth-input"
           prefWidth="190"/>

<TextField fx:id="weightField"
           promptText="Berat (kg)"
           onAction="#focusTarget"
           GridPane.rowIndex="5"
           GridPane.columnIndex="1"
           styleClass="auth-input"
           prefWidth="190"/>

<TextField fx:id="targetField"
           promptText="Target Fitness"
           onAction="#handleRegister"
           GridPane.rowIndex="6"
           GridPane.columnIndex="0"
           GridPane.columnSpan="2"
           styleClass="auth-input"/>

            <Button text="Register"
                    onAction="#handleRegister"
                    GridPane.rowIndex="7"
                    GridPane.columnIndex="0"
                    GridPane.columnSpan="2"
                    maxWidth="Infinity"
                    prefHeight="46"
                    styleClass="auth-btn"/>

            <Label fx:id="messageLabel"
                   GridPane.rowIndex="8"
                   GridPane.columnIndex="0"
                   GridPane.columnSpan="2"
                   wrapText="true"
                   styleClass="auth-message"/>
        </GridPane>

        <Button text="Sudah punya akun? Login"
                onAction="#goToLogin"
                styleClass="auth-link-btn"/>
    </VBox>
</StackPane>