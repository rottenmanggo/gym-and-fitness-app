<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="dashboard.DashboardController"
            stylesheets="@dashboard.css"
            fitToWidth="true"
            styleClass="dashboard-scroll">

    <VBox styleClass="dashboard-root" spacing="25" maxWidth="Infinity">

        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="16">
            <VBox>
                <Label text="Dashboard Admin" styleClass="page-title"/>
                <Label text="Kelola aktivitas gym dengan tampilan yang rapi dan modern."
                       styleClass="page-subtitle"/>
            </VBox>

            <Pane HBox.hgrow="ALWAYS"/>

            <TextField promptText="Cari data..." styleClass="search-input"/>
            <Button text="🔔" styleClass="icon-button"/>

            <HBox styleClass="user-card" alignment="CENTER" spacing="12">
                <Label text="O" styleClass="avatar"/>
                <VBox>
                    <Label text="obama" styleClass="user-name"/>
                    <Label text="Admin" styleClass="user-role"/>
                </VBox>
            </HBox>
        </HBox>

        <VBox styleClass="hero-card" spacing="12">
            <Label text="Admin Overview" styleClass="badge"/>
            <Label text="Kelola operasional GYMBRUT dengan lebih simpel"
                   styleClass="hero-title"/>
            <Label text="Lihat ringkasan member, membership aktif, pembayaran, dan workout program dalam satu dashboard."
                   styleClass="hero-text"
                   wrapText="true"/>
        </VBox>

        <HBox spacing="22" fillHeight="true">
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                <Label text="Total Member" styleClass="stat-label"/>
                <Label text="1,248" styleClass="stat-value"/>
                <Label text="+8.4% dari bulan lalu" styleClass="stat-desc"/>
            </VBox>

            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                <Label text="Membership Aktif" styleClass="stat-label"/>
                <Label text="932" styleClass="stat-value"/>
                <Label text="Paket bulanan paling banyak" styleClass="stat-desc"/>
            </VBox>

            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                <Label text="Pembayaran Pending" styleClass="stat-label"/>
                <Label text="24" styleClass="stat-value"/>
                <Label text="Menunggu verifikasi admin" styleClass="stat-desc"/>
            </VBox>

            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                <Label text="Workout Program" styleClass="stat-label"/>
                <Label text="18" styleClass="stat-value"/>
                <Label text="Siap digunakan member" styleClass="stat-desc"/>
            </VBox>
        </HBox>

        <HBox spacing="24" fillHeight="true">
            <VBox styleClass="content-card" spacing="14" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                <HBox alignment="CENTER_LEFT">
                    <VBox>
                        <Label text="Performa Membership" styleClass="section-title"/>
                        <Label text="Pertumbuhan member aktif dalam 6 bulan terakhir"
                               styleClass="section-subtitle"/>
                    </VBox>

                    <Pane HBox.hgrow="ALWAYS"/>

                    <Label text="Growth Stable" styleClass="green-badge"/>
                </HBox>

                <GridPane styleClass="table-card" hgap="0" vgap="0">
    <columnConstraints>
        <ColumnConstraints percentWidth="25"/>
        <ColumnConstraints percentWidth="25"/>
        <ColumnConstraints percentWidth="25"/>
        <ColumnConstraints percentWidth="25"/>
    </columnConstraints>

    <Label text="Bulan" styleClass="table-head" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
    <Label text="Member Baru" styleClass="table-head" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
    <Label text="Aktif" styleClass="table-head" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
    <Label text="Revenue" styleClass="table-head" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

    <Label text="Januari" styleClass="table-cell" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
    <Label text="42" styleClass="table-cell" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
    <Label text="820" styleClass="table-cell" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
    <Label text="Rp 8.200.000" styleClass="table-cell" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

    <Label text="Februari" styleClass="table-cell" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
    <Label text="58" styleClass="table-cell" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
    <Label text="870" styleClass="table-cell" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
    <Label text="Rp 9.100.000" styleClass="table-cell" GridPane.rowIndex="2" GridPane.columnIndex="3"/>

    <Label text="Maret" styleClass="table-cell" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
    <Label text="71" styleClass="table-cell" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
    <Label text="932" styleClass="table-cell" GridPane.rowIndex="3" GridPane.columnIndex="2"/>
    <Label text="Rp 12.500.000" styleClass="table-cell" GridPane.rowIndex="3" GridPane.columnIndex="3"/>
</GridPane>
            </VBox>

            <VBox styleClass="summary-card" spacing="18">
                <Label text="Ringkasan Operasional" styleClass="section-title"/>

                <HBox>
                    <Label text="Check-in hari ini"/>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <Label text="146 orang" styleClass="bold-text"/>
                </HBox>

                <Separator/>

                <HBox>
                    <Label text="Paket populer"/>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <Label text="Bulanan" styleClass="bold-text"/>
                </HBox>

                <Separator/>

                <HBox>
                    <Label text="Pembayaran verified"/>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <Label text="118 transaksi" styleClass="bold-text"/>
                </HBox>
            </VBox>

        </HBox>

    </VBox>
</ScrollPane>