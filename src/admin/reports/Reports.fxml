<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="admin.reports.ReportsController"
      stylesheets="@reports.css"
      styleClass="reports-root"
      spacing="18">

    <!-- HERO -->
    <HBox styleClass="reports-hero" spacing="22">
        <VBox spacing="9" HBox.hgrow="ALWAYS">
            <Label text="📊 REPORTS OVERVIEW" styleClass="banner-pill"/>
            <Label text="Laporan Performa Gym" styleClass="hero-title"/>
            <Label text="Pantau pendapatan, pertumbuhan member, dan paket paling populer dari satu halaman laporan."
                   wrapText="true"
                   styleClass="hero-desc"/>
        </VBox>

        <VBox spacing="7" styleClass="hero-card">
            <Label text="Paket Terlaris" styleClass="hero-card-label"/>
            <Label fx:id="lblHeroBestPackage" text="Belum ada" styleClass="hero-card-value"/>
            <Label text="Berdasarkan total membership" styleClass="hero-card-sub"/>
        </VBox>
    </HBox>

    <!-- STATS -->
    <HBox spacing="16">
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label text="Pendapatan Hari Ini" styleClass="stat-label"/>
            <Label fx:id="lblTodayIncome" text="Rp0" styleClass="stat-value"/>
            <Label text="Verified payment hari ini" styleClass="stat-meta"/>
        </VBox>

        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label text="Pendapatan Bulan Ini" styleClass="stat-label"/>
            <Label fx:id="lblMonthIncome" text="Rp0" styleClass="stat-value"/>
            <Label text="Total verified bulan berjalan" styleClass="stat-meta"/>
        </VBox>

        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label text="Member Baru" styleClass="stat-label"/>
            <Label fx:id="lblNewMembers" text="0" styleClass="stat-value"/>
            <Label text="Bulan ini" styleClass="stat-meta"/>
        </VBox>

        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label text="Paket Terlaris" styleClass="stat-label"/>
            <Label fx:id="lblBestPackage" text="Belum ada" styleClass="stat-value-small"/>
            <Label text="Paling banyak dipilih" styleClass="stat-meta"/>
        </VBox>
    </HBox>

    <!-- CHARTS -->
    <HBox spacing="18">
        <VBox styleClass="chart-card" spacing="10" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Grafik Pendapatan" styleClass="section-title"/>
                    <Label text="Total pembayaran verified per bulan." styleClass="section-subtitle"/>
                </VBox>

                <Label text="Revenue" styleClass="pill-orange"/>
            </HBox>

            <LineChart fx:id="incomeReportChart"
                       animated="false"
                       legendVisible="false"
                       prefHeight="300">
                <xAxis>
                    <CategoryAxis label="Bulan"/>
                </xAxis>
                <yAxis>
                    <NumberAxis label="Pendapatan"/>
                </yAxis>
            </LineChart>
        </VBox>

        <VBox styleClass="chart-card" spacing="10" prefWidth="430">
            <HBox alignment="CENTER_LEFT">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Pertumbuhan Member" styleClass="section-title"/>
                    <Label text="Jumlah member baru per bulan." styleClass="section-subtitle"/>
                </VBox>

                <Label text="Members" styleClass="pill-blue"/>
            </HBox>

            <BarChart fx:id="memberReportChart"
                      animated="false"
                      legendVisible="false"
                      prefHeight="300">
                <xAxis>
                    <CategoryAxis label="Bulan"/>
                </xAxis>
                <yAxis>
                    <NumberAxis label="Member"/>
                </yAxis>
            </BarChart>
        </VBox>
    </HBox>

    <!-- TABLE -->
    <VBox styleClass="table-card" spacing="16" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT" spacing="14">
            <VBox spacing="4">
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Ringkasan Statistik Bulanan" styleClass="section-title"/>
                    <Label fx:id="totalDataLabel" text="0 data" styleClass="data-count"/>
                </HBox>

                <Label text="Laporan pendapatan, member baru, dan paket terlaris."
                       styleClass="section-subtitle"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <TextField fx:id="searchField"
                       promptText="Cari laporan..."
                       styleClass="search-input"/>

            <Button text="Reset"
                    onAction="#handleReset"
                    styleClass="light-btn"/>

            <Button text="Download"
                    onAction="#handleDownloadReport"
                    styleClass="primary-btn"/>
        </HBox>

        <TableView fx:id="reportTable"
                   prefHeight="320"
                   styleClass="report-table"
                   VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colMonth" text="Bulan" prefWidth="230"/>
                <TableColumn fx:id="colRevenue" text="Pendapatan" prefWidth="230"/>
                <TableColumn fx:id="colNewMembers" text="Member Baru" prefWidth="200"/>
                <TableColumn fx:id="colBestPackage" text="Paket Terlaris" prefWidth="260"/>
            </columns>

            <placeholder>
                <Label text="Belum ada data laporan." styleClass="empty-label"/>
            </placeholder>
        </TableView>
    </VBox>
</VBox>