<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="admin.membership.MembershipController"
      stylesheets="@membership.css"
      styleClass="membership-root"
      spacing="18">

    <HBox styleClass="membership-hero">
        <VBox spacing="8" HBox.hgrow="ALWAYS">
            <Label text="💳 MEMBERSHIP PACKAGES" styleClass="banner-pill"/>
            <Label text="Memberships" styleClass="hero-title"/>
            <Label text="Atur paket membership gym dengan benefit yang jelas dan modern."
                   wrapText="true"
                   styleClass="hero-desc"/>
        </VBox>

        <Button text="+ Tambah Paket"
                onAction="#handleTambahPaket"
                styleClass="primary-btn"/>
    </HBox>

    <VBox styleClass="section-card" spacing="18" VBox.vgrow="ALWAYS">

        <HBox alignment="CENTER_LEFT" spacing="14">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="Paket Membership" styleClass="section-title"/>
                    <Label fx:id="totalDataLabel" text="0 paket" styleClass="data-count"/>
                </HBox>

                <Label text="Pilih dan kelola paket yang tersedia untuk member."
                       styleClass="section-subtitle"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <TextField fx:id="searchField"
                       promptText="Cari paket membership..."
                       styleClass="search-input"/>
        </HBox>

        <ScrollPane fitToWidth="true"
                    styleClass="content-scroll"
                    VBox.vgrow="ALWAYS">
            <GridPane fx:id="cardGrid"
                      hgap="18"
                      vgap="18"
                      styleClass="card-grid">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50"/>
                    <ColumnConstraints percentWidth="50"/>
                </columnConstraints>
            </GridPane>
        </ScrollPane>
    </VBox>
</VBox>