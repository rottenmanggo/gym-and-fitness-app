<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="admin.membership.EditMembershipController"
      stylesheets="@membership.css"
      styleClass="form-page"
      spacing="18">

    <HBox styleClass="form-topbar" alignment="CENTER_LEFT">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Edit Paket Membership" styleClass="form-title"/>
            <Label text="Ubah informasi paket." styleClass="form-subtitle"/>
        </VBox>

        <Button text="← Kembali"
                onAction="#handleKembali"
                styleClass="light-btn"/>
    </HBox>

    <VBox styleClass="form-card" spacing="18">

        <GridPane hgap="18" vgap="14">
            <columnConstraints>
                <ColumnConstraints percentWidth="50"/>
                <ColumnConstraints percentWidth="50"/>
            </columnConstraints>

            <VBox spacing="7" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <Label text="Nama Paket" styleClass="form-label"/>
                <TextField fx:id="tfNama"
                           styleClass="form-control"/>
            </VBox>

            <VBox spacing="7" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <Label text="Durasi Hari" styleClass="form-label"/>
                <TextField fx:id="tfDurasi"
                           styleClass="form-control"/>
            </VBox>

            <VBox spacing="7" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.columnSpan="2">
                <Label text="Harga" styleClass="form-label"/>
                <TextField fx:id="tfHarga"
                           styleClass="form-control"/>
            </VBox>

            <VBox spacing="7" GridPane.columnIndex="0" GridPane.rowIndex="2" GridPane.columnSpan="2">
                <Label text="Deskripsi" styleClass="form-label"/>
                <TextArea fx:id="taDeskripsi"
                          wrapText="true"
                          prefHeight="110"
                          styleClass="form-textarea"/>
            </VBox>
        </GridPane>

        <Button text="Update Paket"
                onAction="#handleUpdate"
                maxWidth="Infinity"
                styleClass="primary-btn"/>
    </VBox>
</VBox>