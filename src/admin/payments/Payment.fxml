<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<!--
  Payment.fxml - Konten halaman Payments (Admin).
  CONTENT-ONLY: tidak mengandung sidebar atau topbar.
  Di-load ke dalam LayoutTop.fxml contentArea secara dinamis.
-->
<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="admin.payments.PaymentController"
      stylesheets="@payment.css"
      styleClass="main-content"
      spacing="0">

    <!-- CONTENT -->
    <VBox spacing="24"
          styleClass="content-body"
          VBox.vgrow="ALWAYS">

        <VBox styleClass="payment-card" spacing="22">

            <!-- SECTION HEADER -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Data Pembayaran" styleClass="section-title"/>
                    <Label text="Approve atau reject pembayaran member." styleClass="section-sub"/>
                </VBox>
                <TextField fx:id="searchField"
                           promptText="🔍  Cari invoice atau nama member..."
                           styleClass="search-field"
                           prefWidth="300"/>
            </HBox>

            <!-- TABLE -->
            <Label fx:id="statusInfo"
                   text=""
                   styleClass="status-info"/>
            <TableView fx:id="paymentTable" VBox.vgrow="ALWAYS" styleClass="payment-table">
                <columns>

                    <TableColumn fx:id="colInvoice"
                                 text="INVOICE"
                                 prefWidth="160"/>

                    <TableColumn fx:id="colNama"
                                 text="MEMBER"
                                 prefWidth="250"/>

                    <TableColumn fx:id="colPaket"
                                 text="PAKET"
                                 prefWidth="150"/>

                    <TableColumn fx:id="colNominal"
                                 text="NOMINAL"
                                 prefWidth="180"/>

                    <TableColumn fx:id="colStatus"
                                 text="STATUS"
                                 prefWidth="160"/>

                    <TableColumn fx:id="colTanggal"
                                 text="TANGGAL"
                                 prefWidth="180"/>

                    <TableColumn fx:id="colBukti"
                                 text="BUKTI"
                                 prefWidth="130"/>

                    <TableColumn fx:id="colAksi"
                                 text="AKSI"
                                 prefWidth="220"/>

                </columns>
                <placeholder>
                    <Label text="Belum ada data pembayaran." styleClass="empty-label"/>
                </placeholder>
            </TableView>

        </VBox>

    </VBox>
</VBox>