<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="admin.workout.AddWorkoutController"
      stylesheets="@workout.css"
      styleClass="form-page"
      spacing="18">

    <HBox styleClass="form-topbar" alignment="CENTER_LEFT">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Tambah Workout" styleClass="form-title"/>
            <Label text="Isi data program latihan baru." styleClass="form-subtitle"/>
        </VBox>

        <Button text="← Kembali"
                onAction="#handleKembali"
                styleClass="light-btn"/>
    </HBox>

    <VBox styleClass="form-card" spacing="18">

        <GridPane hgap="18" vgap="14">
            <columnConstraints>
                <ColumnConstraints percentWidth="50"/>
                <ColumnConstraints percentWidth="50"/>
            </columnConstraints>

            <VBox spacing="7" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <Label text="Kategori" styleClass="form-label"/>
                <ComboBox fx:id="categoryCombo"
                          maxWidth="Infinity"
                          styleClass="form-control"/>
            </VBox>

            <VBox spacing="7" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <Label text="Judul Workout" styleClass="form-label"/>
                <TextField fx:id="titleField"
                           promptText="Contoh: HIIT Fat Burner"
                           styleClass="form-control"/>
            </VBox>

            <VBox spacing="7" GridPane.columnIndex="0" GridPane.rowIndex="1">
                <Label text="Equipment" styleClass="form-label"/>
                <TextField fx:id="equipmentField"
                           promptText="Contoh: Dumbbell, Matras"
                           styleClass="form-control"/>
            </VBox>

            <VBox spacing="7" GridPane.columnIndex="1" GridPane.rowIndex="1">
                <Label text="Youtube URL" styleClass="form-label"/>
                <TextField fx:id="youtubeField"
                           promptText="https://youtube.com/..."
                           styleClass="form-control"/>
            </VBox>

            <VBox spacing="7" GridPane.columnIndex="0" GridPane.rowIndex="2">
                <Label text="Jumlah Set" styleClass="form-label"/>
                <TextField fx:id="setsField"
                           promptText="Contoh: 3"
                           styleClass="form-control"/>
            </VBox>

            <VBox spacing="7" GridPane.columnIndex="1" GridPane.rowIndex="2">
                <Label text="Reps / Durasi" styleClass="form-label"/>
                <TextField fx:id="repsField"
                           promptText="Contoh: 10-12 / 20 menit"
                           styleClass="form-control"/>
            </VBox>

            <VBox spacing="7" GridPane.columnIndex="0" GridPane.rowIndex="3" GridPane.columnSpan="2">
                <Label text="Nama File Gambar" styleClass="form-label"/>
                <TextField fx:id="imageField"
                           promptText="Contoh: workout.jpg"
                           styleClass="form-control"/>
            </VBox>

            <VBox spacing="7" GridPane.columnIndex="0" GridPane.rowIndex="4" GridPane.columnSpan="2">
                <Label text="Tutorial" styleClass="form-label"/>
                <TextArea fx:id="tutorialArea"
                          promptText="Tuliskan langkah-langkah latihan..."
                          wrapText="true"
                          prefHeight="110"
                          styleClass="form-textarea"/>
            </VBox>
        </GridPane>

        <Button text="Simpan Workout"
                onAction="#handleSimpan"
                maxWidth="Infinity"
                styleClass="primary-btn"/>
    </VBox>
</VBox>