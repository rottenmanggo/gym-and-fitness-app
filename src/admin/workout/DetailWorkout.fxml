<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="admin.workout.DetailWorkoutController"
            stylesheets="@workout.css"
            fitToWidth="true"
            styleClass="dialog-scroll">

    <HBox styleClass="detail-page" spacing="18">

        <VBox spacing="16" HBox.hgrow="ALWAYS">
            <VBox styleClass="detail-image-card" alignment="CENTER">
                <Label fx:id="imageLabel"
                       text="Gambar Workout"
                       styleClass="image-placeholder-text"/>
            </VBox>

            <VBox styleClass="detail-card" spacing="10">
                <Label fx:id="titleLabel"
                       text="Judul Workout"
                       styleClass="detail-title"/>

                <Label fx:id="metaLabel"
                       text="Kategori • Set • Reps"
                       styleClass="detail-meta"/>

                <Label fx:id="categoryBadge"
                       text="Workout"
                       styleClass="badge-soft badge-info"/>
            </VBox>

            <VBox styleClass="detail-card" spacing="10">
                <Label text="Deskripsi" styleClass="section-title"/>
                <Label fx:id="descriptionLabel"
                       text="-"
                       wrapText="true"
                       styleClass="section-subtitle"/>

                <Button fx:id="videoButton"
                        text="Buka Video Tutorial"
                        onAction="#handleVideo"
                        styleClass="primary-btn"/>
            </VBox>
        </VBox>

        <VBox styleClass="detail-card" spacing="14" prefWidth="360">
            <Label text="Langkah Latihan" styleClass="section-title"/>
            <VBox fx:id="stepsContainer" spacing="10"/>
        </VBox>

    </HBox>
</ScrollPane>