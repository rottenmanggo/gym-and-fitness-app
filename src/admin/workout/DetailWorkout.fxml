<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="admin.workout.DetailWorkoutController"
      stylesheets="@workout.css"
      styleClass="page-root"
      spacing="0" minWidth="900" minHeight="600">

    <!-- TOP BAR -->
    <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="16">
        <VBox spacing="2" HBox.hgrow="ALWAYS">
            <Label text="GYMBRUT" styleClass="page-title"/>
        </VBox>
        <TextField promptText="🔍  Cari..." styleClass="search-field" prefWidth="220"/>
        <HBox styleClass="avatar-box" alignment="CENTER">
            <Label text="O" styleClass="avatar-label"/>
        </HBox>
        <VBox spacing="1">
            <Label text="obama" styleClass="user-name"/>
            <Label text="Admin" styleClass="user-role"/>
        </VBox>
    </HBox>

    <!-- CONTENT: 2 kolom -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="content-scroll">
        <HBox styleClass="content-body" spacing="24" alignment="TOP_LEFT">

            <!-- KIRI: Info workout -->
            <VBox spacing="16" HBox.hgrow="ALWAYS">
                <!-- Placeholder gambar -->
                <VBox styleClass="img-placeholder" prefHeight="220" alignment="CENTER">
                    <Label fx:id="lblGambar" text="[ Gambar Workout ]" styleClass="img-label"/>
                </VBox>

                <!-- Info card -->
                <VBox styleClass="form-card" spacing="10">
                    <Label fx:id="lblJudul"    styleClass="card-title" text="Judul Workout"/>
                    <Label fx:id="lblMeta"     styleClass="card-meta"  text="Kategori • Set • Reps"/>
                    <HBox spacing="8">
                        <Label fx:id="lblBadge" styleClass="status-badge badge-workout" text="Workout"/>
                    </HBox>
                </VBox>

                <!-- Tutorial / Deskripsi -->
                <VBox styleClass="form-card" spacing="10">
                    <Label text="Tutorial" styleClass="section-title"/>
                    <Label fx:id="lblDeskripsi" styleClass="card-benefit-text" wrapText="true"/>
                    <!-- Video embed placeholder -->
                    <VBox fx:id="videoBox" styleClass="video-placeholder" prefHeight="160" alignment="CENTER">
                        <Label text="▶  Klik tombol Video untuk membuka YouTube" styleClass="video-hint"/>
                    </VBox>
                    <Button fx:id="btnVideo" text="▶  Buka Video Tutorial" styleClass="btn-primary"
                            onAction="#handleVideo"/>
                </VBox>
            </VBox>

            <!-- KANAN: Langkah latihan -->
            <VBox spacing="12" prefWidth="320">
                <Label text="Langkah Latihan" styleClass="section-title"/>
                <VBox fx:id="stepsContainer" spacing="12"/>
            </VBox>

        </HBox>
    </ScrollPane>
</VBox>
