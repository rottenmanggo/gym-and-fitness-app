<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="admin.workout.WorkoutController"
      stylesheets="@workout.css"
      styleClass="workout-root"
      spacing="18">

    <HBox styleClass="workout-hero">
        <VBox spacing="8" HBox.hgrow="ALWAYS">
            <Label text="🔥 WORKOUT PROGRAMS" styleClass="banner-pill"/>
            <Label text="Workouts" styleClass="hero-title"/>
            <Label text="Kelola program latihan yang tersedia untuk seluruh member gym."
                   wrapText="true"
                   styleClass="hero-desc"/>
        </VBox>

        <Button text="+ Tambah Program"
                onAction="#handleTambah"
                styleClass="primary-btn"/>
    </HBox>

    <VBox styleClass="section-card" spacing="18" VBox.vgrow="ALWAYS">

        <HBox alignment="CENTER_LEFT" spacing="14">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="Daftar Program Workout" styleClass="section-title"/>
                    <Label fx:id="totalDataLabel" text="0 program" styleClass="data-count"/>
                </HBox>

                <Label text="Program latihan modern yang bisa dipilih sesuai tujuan fitness."
                       styleClass="section-subtitle"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <TextField fx:id="searchField"
                           promptText="Cari program workout..."
                           styleClass="search-input"/>

                <Button text="Reset"
                        onAction="#handleReset"
                        styleClass="light-btn"/>
            </HBox>
        </HBox>

        <ScrollPane fitToWidth="true"
                    styleClass="content-scroll"
                    VBox.vgrow="ALWAYS">
            <GridPane fx:id="cardGrid"
                      hgap="18"
                      vgap="18"
                      styleClass="card-grid">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50"/>
                    <ColumnConstraints percentWidth="50"/>
                </columnConstraints>
            </GridPane>
        </ScrollPane>
    </VBox>
</VBox>