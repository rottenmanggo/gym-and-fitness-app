<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="admin.workout.WorkoutController"
      stylesheets="@workout.css"
      styleClass="page-root"
      spacing="0">

    <!-- TOP BAR -->
    <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="16">
        <VBox spacing="2" HBox.hgrow="ALWAYS">
            <Label text="Workouts" styleClass="page-title"/>
            <Label text="Kelola program latihan yang tersedia untuk seluruh member gym." styleClass="page-subtitle"/>
        </VBox>
        <TextField fx:id="searchField" promptText="🔍  Cari program workout..." styleClass="search-field" prefWidth="280"/>
        <HBox styleClass="avatar-box" alignment="CENTER">
            <Label text="O" styleClass="avatar-label"/>
        </HBox>
        <VBox spacing="1">
            <Label text="obama" styleClass="user-name"/>
            <Label text="Admin" styleClass="user-role"/>
        </VBox>
    </HBox>

    <!-- CONTENT -->
    <ScrollPane styleClass="content-scroll" fitToWidth="true" VBox.vgrow="ALWAYS">
        <VBox spacing="24" styleClass="content-body">

            <!-- SECTION HEADER -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Daftar Program Workout" styleClass="section-title"/>
                    <Label text="Program latihan modern yang bisa dipilih sesuai tujuan fitness." styleClass="section-sub"/>
                </VBox>
                <Button text="+ Tambah Program" styleClass="btn-primary" onAction="#handleTambah"/>
            </HBox>

            <!-- CARD GRID -->
            <GridPane fx:id="cardGrid" hgap="20" vgap="20">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50"/>
                    <ColumnConstraints percentWidth="50"/>
                </columnConstraints>
            </GridPane>

        </VBox>
    </ScrollPane>
</VBox>
