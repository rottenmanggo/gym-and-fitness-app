<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="member.payments.MemberPaymentsController"
      stylesheets="@../../assets/css/style.css"
      styleClass="member-dashboard-page"
      spacing="22">

    <HBox styleClass="dashboard-hero" spacing="20">
        <VBox spacing="10" HBox.hgrow="ALWAYS">
            <Label text="💳 Payment Member" styleClass="banner-pill"/>
            <Label text="Pembayaran Membership" styleClass="hero-title"/>
            <Label text="Scan QR pembayaran, lalu upload bukti transfer. Admin akan memverifikasi pembayaran kamu."
                   wrapText="true"
                   styleClass="hero-desc"/>
        </VBox>

        <VBox styleClass="dashboard-hero-card" spacing="7">
            <Label text="Total Pembayaran" styleClass="hero-card-label"/>
            <Label fx:id="totalPaymentHeroLabel"
                   text="0"
                   styleClass="hero-card-value"/>
            <Label text="Riwayat pembayaran kamu" styleClass="hero-card-sub"/>
        </VBox>
    </HBox>

    <Label fx:id="messageLabel"
           text=""
           managed="false"
           visible="false"
           styleClass="alert-box"/>

    <VBox fx:id="pendingPaymentCard"
          styleClass="premium-card"
          spacing="18"
          managed="false"
          visible="false">

        <HBox styleClass="card-header-inline">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="QR Pembayaran" styleClass="section-title"/>
                <Label text="Scan QR berikut untuk melakukan pembayaran, lalu upload bukti pembayaran."
                       wrapText="true"
                       styleClass="section-subtitle"/>
            </VBox>

            <Label fx:id="pendingStatusBadge"
                   text="Pending"
                   styleClass="badge-soft badge-pending"/>
        </HBox>

        <HBox spacing="24" alignment="CENTER_LEFT">
            <VBox styleClass="payment-qr-box" alignment="CENTER" spacing="8">
                <ImageView fx:id="qrImageView"
                           fitWidth="190"
                           fitHeight="190"
                           preserveRatio="true"/>

                <Label text="GYMBRUT PAYMENT" styleClass="qr-subtext"/>
            </VBox>

            <VBox spacing="12" HBox.hgrow="ALWAYS">
                <Label fx:id="pendingPackageLabel"
                       text="Paket Membership"
                       styleClass="payment-pending-title"/>

                <VBox styleClass="metric-list" spacing="0">
                    <HBox styleClass="metric-row">
                        <Label text="Invoice" styleClass="metric-label"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="pendingInvoiceLabel" text="#PAY-0000" styleClass="metric-value"/>
                    </HBox>

                    <HBox styleClass="metric-row">
                        <Label text="Nominal" styleClass="metric-label"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="pendingAmountLabel" text="Rp0" styleClass="metric-value"/>
                    </HBox>

                    <HBox styleClass="metric-row">
                        <Label text="Periode" styleClass="metric-label"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="pendingPeriodLabel" text="-" styleClass="metric-value"/>
                    </HBox>

                    <HBox styleClass="metric-row">
                        <Label text="Bukti" styleClass="metric-label"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="selectedFileLabel" text="Belum pilih file" styleClass="metric-value"/>
                    </HBox>
                </VBox>

                <HBox spacing="10">
                    <Button text="Pilih Bukti"
                            onAction="#handleChooseProof"
                            styleClass="light-btn"/>

                    <Button fx:id="uploadButton"
                            text="Upload Bukti Pembayaran"
                            onAction="#handleUploadProof"
                            styleClass="primary-btn"/>
                </HBox>

                <Label text="Format file: JPG, JPEG, PNG, atau PDF. Ukuran maksimal 2MB."
                       wrapText="true"
                       styleClass="text-soft"/>
            </VBox>
        </HBox>
    </VBox>

    <VBox fx:id="noPendingCard"
          styleClass="premium-card"
          spacing="10"
          managed="false"
          visible="false">
        <Label text="Tidak ada pembayaran pending" styleClass="section-title"/>
        <Label text="Jika kamu baru memilih paket membership, invoice pembayaran akan muncul di sini."
               wrapText="true"
               styleClass="section-subtitle"/>
    </VBox>

    <VBox styleClass="premium-card" spacing="16">
        <HBox styleClass="card-header-inline">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Riwayat Pembayaran" styleClass="section-title"/>
                <Label text="Pantau semua pembayaran membership kamu."
                       styleClass="section-subtitle"/>
            </VBox>

            <Label fx:id="historyCountLabel"
                   text="0 data"
                   styleClass="data-count"/>
        </HBox>

        <VBox styleClass="payment-table-card" spacing="0">
            <HBox styleClass="payment-table-header">
                <Label text="Invoice" styleClass="payment-th" HBox.hgrow="ALWAYS"/>
                <Label text="Paket" styleClass="payment-th" HBox.hgrow="ALWAYS"/>
                <Label text="Nominal" styleClass="payment-th" HBox.hgrow="ALWAYS"/>
                <Label text="Tanggal" styleClass="payment-th" HBox.hgrow="ALWAYS"/>
                <Label text="Bukti" styleClass="payment-th" HBox.hgrow="ALWAYS"/>
                <Label text="Status" styleClass="payment-th" HBox.hgrow="ALWAYS"/>
            </HBox>

            <VBox fx:id="historyContainer"/>
        </VBox>
    </VBox>

</VBox>