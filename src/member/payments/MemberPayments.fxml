<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" alignment="CENTER" xmlns:fx="http://javafx.com/fxml"
      fx:controller="member.payments.MemberPaymentsController">

    <Label text="Member Payments" style="-fx-font-size: 18px;" />

    <TableView fx:id="paymentTable" prefWidth="400">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
            <TableColumn fx:id="colAmount" text="Amount" prefWidth="150"/>
            <TableColumn fx:id="colStatus" text="Status" prefWidth="150"/>
        </columns>
    </TableView>

    <Button text="Upload Payment" onAction="#handleGoToUpload"/>

</VBox>