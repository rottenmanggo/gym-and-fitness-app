<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="member.workout.MemberWorkoutsController"
      stylesheets="@../../assets/css/style.css"
      styleClass="member-dashboard-page"
      spacing="22">

    <HBox styleClass="dashboard-hero" spacing="20">
        <VBox spacing="10" HBox.hgrow="ALWAYS">
            <Label text="⚡ Workout Library" styleClass="banner-pill"/>
            <Label text="Daftar Workout" styleClass="hero-title"/>
            <Label text="Pilih latihan sesuai tujuan fitness kamu. Gunakan filter kategori untuk mencari workout seperti Fat Loss, Bulking, Cardio, Strength, dan Beginner."
                   wrapText="true"
                   styleClass="hero-desc"/>
        </VBox>

        <VBox styleClass="dashboard-hero-card" spacing="7">
            <Label text="Status Membership" styleClass="hero-card-label"/>
            <Label fx:id="heroStatusLabel"
                   text="Tidak Aktif"
                   styleClass="hero-card-value"/>
            <Label fx:id="heroPackageLabel"
                   text="Belum ada membership aktif"
                   styleClass="hero-card-sub"/>
        </VBox>
    </HBox>

    <HBox spacing="18" styleClass="stats-row">
        <VBox styleClass="stat-card stat-card-modern" spacing="8" HBox.hgrow="ALWAYS">
            <Label text="Total Workout" styleClass="stat-label"/>
            <Label fx:id="totalWorkoutLabel"
                   text="0"
                   styleClass="stat-value"/>
            <Label text="Semua workout tersedia"
                   styleClass="stat-desc"/>
        </VBox>

        <VBox styleClass="stat-card stat-card-modern" spacing="8" HBox.hgrow="ALWAYS">
            <Label text="Kategori" styleClass="stat-label"/>
            <Label fx:id="totalCategoryLabel"
                   text="0"
                   styleClass="stat-value"/>
            <Label text="Jenis latihan tersedia"
                   styleClass="stat-desc"/>
        </VBox>

        <VBox styleClass="stat-card stat-card-modern" spacing="8" HBox.hgrow="ALWAYS">
            <Label text="Hasil Filter" styleClass="stat-label"/>
            <Label fx:id="filteredWorkoutLabel"
                   text="0"
                   styleClass="stat-value"/>
            <Label text="Workout yang sedang tampil"
                   styleClass="stat-desc"/>
        </VBox>
    </HBox>

    <VBox styleClass="premium-card" spacing="16">
        <HBox styleClass="card-header-inline">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Filter Workout" styleClass="section-title"/>
                <Label text="Cari berdasarkan nama workout, kategori, equipment, atau tutorial."
                       styleClass="section-subtitle"/>
            </VBox>

            <Label fx:id="membershipBadge"
                   text="Tidak Aktif"
                   styleClass="badge-soft badge-failed"/>
        </HBox>

        <HBox spacing="12" alignment="CENTER_LEFT">
            <VBox spacing="7" HBox.hgrow="ALWAYS">
                <Label text="Cari Workout" styleClass="form-label"/>
                <TextField fx:id="searchField"
                           promptText="Contoh: cardio, dumbbell, beginner..."
                           styleClass="form-control"/>
            </VBox>

            <VBox spacing="7" prefWidth="260">
                <Label text="Kategori" styleClass="form-label"/>
                <ComboBox fx:id="categoryCombo"
                          maxWidth="Infinity"
                          styleClass="form-control"/>
            </VBox>

            <VBox spacing="7" prefWidth="190">
                <Label text="Aksi" styleClass="form-label"/>
                <HBox spacing="8">
                    <Button text="Filter"
                            onAction="#handleFilter"
                            styleClass="primary-btn"/>

                    <Button text="Reset"
                            onAction="#handleReset"
                            styleClass="light-btn"/>
                </HBox>
            </VBox>
        </HBox>

        <Label fx:id="membershipNoteLabel"
               text="Catatan: membership kamu belum aktif. Kamu tetap bisa melihat daftar workout, tapi untuk check-in dan progress harus memiliki membership aktif."
               wrapText="true"
               styleClass="text-soft"/>
    </VBox>

    <VBox styleClass="premium-card" spacing="16" VBox.vgrow="ALWAYS">
        <HBox styleClass="card-header-inline">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Program Workout" styleClass="section-title"/>
                <Label text="Daftar latihan dari database workout."
                       styleClass="section-subtitle"/>
            </VBox>

            <Label fx:id="workoutCountLabel"
                   text="0 workout"
                   styleClass="data-count"/>
        </HBox>

        <ScrollPane fitToWidth="true"
                    styleClass="content-scroll"
                    VBox.vgrow="ALWAYS">
            <GridPane fx:id="workoutGrid"
                      hgap="18"
                      vgap="18"
                      styleClass="member-workout-grid">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50"/>
                    <ColumnConstraints percentWidth="50"/>
                </columnConstraints>
            </GridPane>
        </ScrollPane>
    </VBox>

</VBox>