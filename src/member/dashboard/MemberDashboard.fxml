<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<!--
  MemberDashboard.fxml - Konten halaman Dashboard Member.
  CONTENT-ONLY: tidak mengandung sidebar atau topbar.
  Di-load ke dalam LayoutTop.fxml contentArea secara dinamis.
-->
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="member.dashboard.MemberDashboardController"
      spacing="22"
      styleClass="content">
    <padding>
        <Insets top="8" right="4" bottom="16" left="4"/>
    </padding>

    <!-- Greeting -->
    <HBox alignment="CENTER_LEFT">
        <VBox spacing="4">
            <Label fx:id="greetingLabel" text="Halo, Member 👋" styleClass="page-title"/>
            <Label text="Selamat datang di dashboard GYMBRUT" styleClass="page-subtitle"/>
        </VBox>
    </HBox>

    <!-- Stat Cards -->
    <HBox spacing="18">
        <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
            <Label text="Status Membership" styleClass="stat-label"/>
            <Label text="Aktif" styleClass="stat-value"/>
            <Label text="Berlaku sampai 30 hari lagi" styleClass="stat-desc"/>
        </VBox>

        <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
            <Label text="Kunjungan Bulan Ini" styleClass="stat-label"/>
            <Label text="12x" styleClass="stat-value"/>
            <Label text="Target 20x kunjungan" styleClass="stat-desc"/>
        </VBox>

        <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
            <Label text="Kelas Terjadwal" styleClass="stat-label"/>
            <Label text="3" styleClass="stat-value"/>
            <Label text="Minggu ini" styleClass="stat-desc"/>
        </VBox>
    </HBox>

    <!-- Panels -->
    <HBox spacing="18" VBox.vgrow="ALWAYS">
        <VBox styleClass="panel-card" spacing="14" HBox.hgrow="ALWAYS">
            <Label text="Jadwal Latihan Hari Ini" styleClass="section-title"/>
            <Label text="• 08:00 - Cardio Session" styleClass="list-text"/>
            <Label text="• 16:00 - Strength Training" styleClass="list-text"/>
            <Label text="• 19:00 - Yoga Class" styleClass="list-text"/>
        </VBox>

        <VBox styleClass="panel-card" spacing="14" HBox.hgrow="ALWAYS">
            <Label text="Progress Singkat" styleClass="section-title"/>
            <Label text="Berat badan: 68 kg" styleClass="list-text"/>
            <Label text="Kalori terbakar: 4.250 kcal" styleClass="list-text"/>
            <Label text="Durasi latihan: 14 jam" styleClass="list-text"/>
            <Button text="Lihat Detail" styleClass="small-orange-btn"/>
        </VBox>
    </HBox>
</VBox>