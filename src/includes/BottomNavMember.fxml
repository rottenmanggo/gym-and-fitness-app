<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>

<!--
  BottomNavMember.fxml - Bottom navigation bar untuk Member (mobile-like).
  Ditampilkan di bagian bawah halaman member sebagai alternatif navigasi.
-->
<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="includes.BottomNavMemberController"
      styleClass="bottom-nav"
      alignment="CENTER"
      spacing="0">

    <Button fx:id="btnNavDashboard"
            text="▦&#10;Home"
            onAction="#navigateDashboard"
            styleClass="bottom-nav-btn-active"
            HBox.hgrow="ALWAYS"
            maxWidth="Infinity" />

    <Button fx:id="btnNavWorkout"
            text="🔥&#10;Latihan"
            onAction="#navigateWorkout"
            styleClass="bottom-nav-btn"
            HBox.hgrow="ALWAYS"
            maxWidth="Infinity" />

    <Button fx:id="btnNavCheckin"
            text="📍&#10;Check-in"
            onAction="#navigateCheckin"
            styleClass="bottom-nav-btn"
            HBox.hgrow="ALWAYS"
            maxWidth="Infinity" />

    <Button fx:id="btnNavNotif"
            text="🔔&#10;Notifikasi"
            onAction="#navigateNotifications"
            styleClass="bottom-nav-btn"
            HBox.hgrow="ALWAYS"
            maxWidth="Infinity" />

    <Button fx:id="btnNavProfile"
            text="👤&#10;Profil"
            onAction="#navigateProfile"
            styleClass="bottom-nav-btn"
            HBox.hgrow="ALWAYS"
            maxWidth="Infinity" />

</HBox>
