<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!--
  SidebarAdmin.fxml - Navigasi sidebar untuk role Admin.
  Menampilkan brand, menu navigasi admin, dan footer logout.
-->
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="includes.SidebarAdminController"
      styleClass="sidebar"
      spacing="6">

    <!-- Brand / Logo -->
    <HBox styleClass="sidebar-brand">
        <ImageView fitWidth="46" fitHeight="46"
                   preserveRatio="true"
                   styleClass="sidebar-logo-img">
            <image>
                <Image url="@../assets/img/logo-g.png" />
            </image>
        </ImageView>
        <VBox>
            <Label text="GYMBRUT" styleClass="brand-title" />
            <Label text="ADMIN PANEL" styleClass="brand-subtitle" />
        </VBox>
    </HBox>

    <Separator />

    <!-- Section Title -->
    <Label text="MAIN MENU" styleClass="sidebar-title" />

    <!-- Navigation Links -->
    <VBox styleClass="sidebar-nav">
        <Button fx:id="btnDashboard"
                text="▦   Dashboard"
                onAction="#navigateDashboard"
                styleClass="sidebar-link-active" />
        <Button fx:id="btnMembers"
                text="👥  Members"
                onAction="#navigateMembers"
                styleClass="sidebar-link" />
        <Button fx:id="btnMemberships"
                text="▤   Memberships"
                onAction="#navigateMemberships"
                styleClass="sidebar-link" />
        <Button fx:id="btnPayments"
                text="💳  Payments"
                onAction="#navigatePayments"
                styleClass="sidebar-link" />
        <Button fx:id="btnReports"
                text="📊  Reports"
                onAction="#navigateReports"
                styleClass="sidebar-link" />
        <Button fx:id="btnWorkouts"
                text="🔥  Workouts"
                onAction="#navigateWorkouts"
                styleClass="sidebar-link" />
    </VBox>

    <!-- Spacer -->
    <Region VBox.vgrow="ALWAYS" />

    <!-- Footer -->
    <VBox styleClass="sidebar-footer">
        <Label fx:id="adminNameLabel" text="Admin" styleClass="sidebar-user-name" />
        <Label text="Administrator" styleClass="sidebar-user-role" />
        <Button text="↪  Logout"
                onAction="#handleLogout"
                styleClass="logout-btn" />
    </VBox>

</VBox>
