<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="includes.SidebarMemberController"
      styleClass="sidebar"
      spacing="6">

    <!-- BRAND -->
    <HBox styleClass="sidebar-brand" spacing="12">
        <ImageView fitWidth="46"
                   fitHeight="46"
                   preserveRatio="true"
                   styleClass="sidebar-logo-img">
            <image>
                <Image url="@../assets/image/logo-gymbrut.png"/>
            </image>
        </ImageView>

        <VBox spacing="2">
            <Label text="GYMBRUT" styleClass="brand-title"/>
            <Label text="MEMBER PANEL" styleClass="brand-subtitle"/>
        </VBox>
    </HBox>

    <Separator/>

    <Label text="MAIN MENU" styleClass="sidebar-title"/>

    <!-- MENU -->
    <VBox styleClass="sidebar-nav" spacing="6">
        <Button fx:id="btnDashboard"
                text="▦   Dashboard"
                onAction="#navigateDashboard"
                maxWidth="Infinity"
                styleClass="sidebar-link-active"/>

        <Button fx:id="btnMembership"
                text="🏆  Membership"
                onAction="#navigateMembership"
                maxWidth="Infinity"
                styleClass="sidebar-link"/>

        <Button fx:id="btnPayments"
                text="💳  Payments"
                onAction="#navigatePayments"
                maxWidth="Infinity"
                styleClass="sidebar-link"/>

        <Button fx:id="btnCheckin"
                text="↪  Check In"
                onAction="#navigateCheckin"
                maxWidth="Infinity"
                styleClass="sidebar-link"/>

        <Button fx:id="btnWorkouts"
                text="⚡  Workouts"
                onAction="#navigateWorkouts"
                maxWidth="Infinity"
                styleClass="sidebar-link"/>

        <Button fx:id="btnProfile"
                text="👤  Profile"
                onAction="#navigateProfile"
                maxWidth="Infinity"
                styleClass="sidebar-link"/>
    </VBox>

    <Region VBox.vgrow="ALWAYS"/>

    <!-- FOOTER -->
    <VBox styleClass="sidebar-footer" spacing="8">
        <Label fx:id="memberNameLabel"
               text="Member"
               styleClass="sidebar-user-name"/>

        <Label text="Gym Member"
               styleClass="sidebar-user-role"/>

        <Button text="↪  Logout"
                onAction="#handleLogout"
                maxWidth="Infinity"
                styleClass="logout-btn"/>
    </VBox>

</VBox>