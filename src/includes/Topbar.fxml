<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>

<!--
  Topbar.fxml - Komponen topbar global.
  Menampilkan judul halaman, search, notifikasi, dan data user dari session.
  Dapat di-include di dalam layout utama.
-->
<HBox xmlns:fx="http://javafx.com/fxml"
    fx:controller="includes.TopbarController"
    styleClass="topbar"
    alignment="CENTER_LEFT"
    spacing="16">

    <!-- Left: Title & Subtitle -->
    <VBox spacing="4">
        <Label fx:id="pageTitle" text="Dashboard" styleClass="topbar-title" />
        <Label fx:id="pageSubtitle" text="Ringkasan operasional GYMBRUT"
            styleClass="topbar-subtitle" />
    </VBox>

    <!-- Spacer -->
    <Region HBox.hgrow="ALWAYS" />

    <!-- Right Section -->
    <HBox styleClass="topbar-right" alignment="CENTER_RIGHT" spacing="12">
        <StackPane>
            <Button fx:id="notifButton"
                text="🔔"
                onAction="#handleNotification"
                styleClass="notif-btn" />

            <Label fx:id="notifBadge"
                text="3"
                visible="false"
                managed="false"
                StackPane.alignment="TOP_RIGHT"
                styleClass="notif-badge" />
        </StackPane>

        <HBox fx:id="profileButton"
            styleClass="topbar-user-box"
            spacing="10"
            alignment="CENTER"
            onMouseClicked="#handleProfileClick">
            <Label fx:id="userAvatar"
                text="A"
                styleClass="topbar-user-avatar" />

            <VBox spacing="2" minWidth="76" prefWidth="92">
                <Label fx:id="usernameLabel"
                    text="Admin"
                    styleClass="topbar-username" />

                <Label fx:id="roleLabel"
                    text="Member"
                    styleClass="topbar-role" />
            </VBox>
        </HBox>
    </HBox>

</HBox>