<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_outline"
    android:orientation="horizontal"
    android:padding="16dp">
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tvExercise" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/gym_text" android:textStyle="bold"/>
        <TextView android:id="@+id/tvSetsReps" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:textColor="@color/gym_subtext"/>
    </LinearLayout>
    <TextView android:id="@+id/tvWeight" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/gym_lime" android:textStyle="bold"/>
</LinearLayout>