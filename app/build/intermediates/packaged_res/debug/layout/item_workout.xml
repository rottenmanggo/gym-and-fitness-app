<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:padding="18dp">
    <TextView android:id="@+id/tvWorkoutName" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/gym_text" android:textSize="22sp" android:textStyle="bold"/>
    <TextView android:id="@+id/tvWorkoutMeta" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:textColor="@color/gym_subtext"/>
    <TextView android:id="@+id/tvWorkoutSteps" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:textColor="@color/gym_text"/>
</LinearLayout>