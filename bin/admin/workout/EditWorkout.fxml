<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="admin.workout.EditWorkoutController"
      stylesheets="@workout.css"
      styleClass="page-root"
      spacing="0" minWidth="760">

    <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="16">
        <VBox spacing="2" HBox.hgrow="ALWAYS">
            <Label text="Edit Workout" styleClass="page-title"/>
        </VBox>
        <HBox styleClass="avatar-box" alignment="CENTER">
            <Label text="O" styleClass="avatar-label"/>
        </HBox>
        <VBox spacing="1">
            <Label text="obama" styleClass="user-name"/>
            <Label text="Admin" styleClass="user-role"/>
        </VBox>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="content-scroll">
        <VBox styleClass="content-body" spacing="20">

            <VBox styleClass="form-card" spacing="20">
                <Label text="Informasi Workout" styleClass="section-title"/>
                <Separator/>

                <GridPane hgap="20" vgap="4">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="50"/>
                        <ColumnConstraints percentWidth="50"/>
                    </columnConstraints>
                    <Label text="Judul Workout" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="tfJudul" styleClass="form-field" GridPane.columnIndex="0" GridPane.rowIndex="1"/>

                    <Label text="Kategori" styleClass="form-label" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <TextField fx:id="tfKategori" styleClass="form-field" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                </GridPane>

                <GridPane hgap="20" vgap="4">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="50"/>
                        <ColumnConstraints percentWidth="50"/>
                    </columnConstraints>
                    <Label text="Equipment" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="tfEquipment" styleClass="form-field" GridPane.columnIndex="0" GridPane.rowIndex="1"/>

                    <Label text="Jumlah Set" styleClass="form-label" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <TextField fx:id="tfSets" styleClass="form-field" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                </GridPane>

                <GridPane hgap="20" vgap="4">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="50"/>
                        <ColumnConstraints percentWidth="50"/>
                    </columnConstraints>
                    <Label text="Repetisi / Durasi" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="tfReps" styleClass="form-field" GridPane.columnIndex="0" GridPane.rowIndex="1"/>

                    <Label text="Link Video" styleClass="form-label" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <TextField fx:id="tfVideo" styleClass="form-field" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                </GridPane>

                <VBox spacing="4">
                    <Label text="Deskripsi Latihan" styleClass="form-label"/>
                    <TextArea fx:id="taDeskripsi" styleClass="form-field"
                              prefHeight="100" wrapText="true"/>
                </VBox>

                <VBox spacing="4">
                    <Label text="Gambar Workout (nama file)" styleClass="form-label"/>
                    <TextField fx:id="tfGambar" styleClass="form-field"/>
                </VBox>

                <Button text="💾  Update Program" styleClass="btn-primary btn-full"
                        maxWidth="Infinity" onAction="#handleUpdate"/>
            </VBox>
        </VBox>
    </ScrollPane>
</VBox>
