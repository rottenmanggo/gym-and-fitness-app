<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="admin.membership.AddMembershipController"
      stylesheets="@membership.css"
      styleClass="page-root"
      spacing="0" minWidth="700">

    <!-- TOP BAR -->
    <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="16">
        <VBox spacing="2" HBox.hgrow="ALWAYS">
            <Label text="Tambah Paket Membership" styleClass="page-title"/>
            <Label text="Tambahkan paket membership baru untuk member." styleClass="page-subtitle"/>
        </VBox>
        <TextField promptText="🔍  Cari..." styleClass="search-field" prefWidth="220"/>
        <HBox styleClass="avatar-box" alignment="CENTER">
            <Label text="O" styleClass="avatar-label"/>
        </HBox>
        <VBox spacing="1">
            <Label text="obama" styleClass="user-name"/>
            <Label text="Admin" styleClass="user-role"/>
        </VBox>
    </HBox>

    <!-- CONTENT -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="content-scroll">
        <VBox styleClass="content-body" spacing="20">

            <!-- SECTION CARD -->
            <VBox styleClass="form-card" spacing="20">
                <HBox alignment="CENTER_LEFT">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Tambah Paket Membership" styleClass="section-title"/>
                        <Label text="Isi detail paket baru." styleClass="section-sub"/>
                    </VBox>
                    <Button text="← Kembali" styleClass="btn-back" onAction="#handleKembali"/>
                </HBox>

                <Separator/>

                <!-- ROW 1: Nama + Durasi -->
                <GridPane hgap="20" vgap="4">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="50"/>
                        <ColumnConstraints percentWidth="50"/>
                    </columnConstraints>
                    <Label text="Nama Paket" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="tfNama" styleClass="form-field" GridPane.columnIndex="0" GridPane.rowIndex="1"/>

                    <Label text="Durasi Hari" styleClass="form-label" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <TextField fx:id="tfDurasi" styleClass="form-field" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                </GridPane>

                <!-- ROW 2: Harga -->
                <VBox spacing="4">
                    <Label text="Harga" styleClass="form-label"/>
                    <TextField fx:id="tfHarga" styleClass="form-field"/>
                </VBox>

                <!-- ROW 3: Deskripsi -->
                <VBox spacing="4">
                    <Label text="Deskripsi" styleClass="form-label"/>
                    <TextArea fx:id="taDeskripsi" styleClass="form-field"
                              promptText="Contoh: Akses gym selama 30 hari"
                              prefHeight="100" wrapText="true"/>
                </VBox>

                <!-- BUTTON SIMPAN -->
                <Button text="💾  Simpan Paket" styleClass="btn-primary btn-full"
                        maxWidth="Infinity" onAction="#handleSimpan"/>
            </VBox>

        </VBox>
    </ScrollPane>
</VBox>
