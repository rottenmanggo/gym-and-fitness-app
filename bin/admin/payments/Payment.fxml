<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="payment.PaymentController"
      styleClass="page-root"
      stylesheets="@payment.css"
      spacing="0">

    <!-- TOP BAR -->
    <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="16">
        <VBox spacing="2" HBox.hgrow="ALWAYS">
            <Label text="Payments" styleClass="page-title"/>
            <Label text="Pantau status pembayaran member dan invoice secara real-time." styleClass="page-subtitle"/>
        </VBox>
        <TextField fx:id="searchField" promptText="🔍  Cari invoice atau nama member..." styleClass="search-field" prefWidth="300"/>
        <HBox styleClass="avatar-box" alignment="CENTER">
            <Label text="O" styleClass="avatar-label"/>
        </HBox>
        <VBox spacing="1">
            <Label text="obama" styleClass="user-name"/>
            <Label text="Admin" styleClass="user-role"/>
        </VBox>
    </HBox>

    <!-- CONTENT -->
    <VBox spacing="20" styleClass="content-body" VBox.vgrow="ALWAYS">

        <!-- SECTION HEADER -->
        <HBox alignment="CENTER_LEFT" spacing="12">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Riwayat Pembayaran" styleClass="section-title"/>
                <Label text="Semua transaksi member dalam satu tabel yang rapi." styleClass="section-sub"/>
            </VBox>
            <Button text="⬇  Export" styleClass="btn-export" onAction="#handleExport"/>
        </HBox>

        <!-- ACTION BUTTONS -->
        <HBox spacing="12" alignment="CENTER_LEFT">
            <Button text="✓  Approve" styleClass="btn-approve" onAction="#handleApprove"/>
            <Button text="✗  Reject"  styleClass="btn-reject"  onAction="#handleReject"/>
            <Label fx:id="statusInfo" styleClass="status-info" text=""/>
        </HBox>

        <!-- TABLE -->
        <TableView fx:id="paymentTable" VBox.vgrow="ALWAYS" styleClass="payment-table">
            <columns>
                <TableColumn fx:id="colInvoice" text="INVOICE"      prefWidth="130"/>
                <TableColumn fx:id="colNama"    text="NAMA MEMBER"  prefWidth="200"/>
                <TableColumn fx:id="colNominal" text="NOMINAL"      prefWidth="140"/>
                <TableColumn fx:id="colMetode"  text="METODE"       prefWidth="150"/>
                <TableColumn fx:id="colStatus"  text="STATUS"       prefWidth="120"/>
                <TableColumn fx:id="colTanggal" text="TANGGAL"      prefWidth="140"/>
            </columns>
            <placeholder>
                <Label text="Belum ada data pembayaran." styleClass="empty-label"/>
            </placeholder>
        </TableView>

    </VBox>

</VBox>
