<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="auth.RegisterController"
           stylesheets="@auth.css"
           prefWidth="1100"
           prefHeight="720"
           styleClass="auth-page">

    <VBox styleClass="auth-card">

        <Label text="GYMBRUT" styleClass="auth-title" />

        <Label text="Register akun member"
               wrapText="true"
               styleClass="auth-subtitle" />

        <Label fx:id="alertLabel"
               text=""
               visible="false"
               managed="false"
               wrapText="true"
               styleClass="auth-alert" />

        <VBox styleClass="auth-form">

            <VBox styleClass="form-group">
                <Label text="Nama" styleClass="form-label" />
                <TextField fx:id="nameField"
                           promptText="Masukkan nama"
                           styleClass="form-control" />
            </VBox>

            <VBox styleClass="form-group">
                <Label text="Email" styleClass="form-label" />
                <TextField fx:id="emailField"
                           promptText="Masukkan email"
                           styleClass="form-control" />
            </VBox>

            <VBox styleClass="form-group">
                <Label text="No HP" styleClass="form-label" />
                <TextField fx:id="phoneField"
                           promptText="Masukkan nomor HP"
                           styleClass="form-control" />
            </VBox>

            <VBox styleClass="form-group">
                <Label text="Password" styleClass="form-label" />
                <PasswordField fx:id="passwordField"
                               promptText="Masukkan password"
                               styleClass="form-control" />
            </VBox>

            <Button text="Register"
                    onAction="#handleRegister"
                    styleClass="gradient-btn" />

        </VBox>

        <Hyperlink text="Sudah punya akun? Login"
                   onAction="#handleLoginLink"
                   styleClass="auth-link" />

    </VBox>

</StackPane>