<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="auth.LoginController"
           stylesheets="@auth.css"
           prefWidth="1100"
           prefHeight="720"
           styleClass="auth-page">

    <VBox styleClass="auth-card">

        <Label text="🏋" styleClass="auth-logo" />

        <Label text="GYMBRUT" styleClass="auth-title" />

        <Label text="Login ke sistem fitness &amp; gym management"
               wrapText="true"
               styleClass="auth-subtitle" />

        <Label fx:id="alertLabel"
       text=""
       wrapText="true"
       maxWidth="380"
       visible="false"
       managed="false"
       styleClass="auth-alert" />

        <VBox styleClass="auth-form">

            <VBox styleClass="form-group">
                <Label text="Email" styleClass="form-label" />
                <TextField fx:id="emailField"
                           promptText="Masukkan email"
                           styleClass="form-control" />
            </VBox>

            <VBox styleClass="form-group">
                <Label text="Password" styleClass="form-label" />
                <PasswordField fx:id="passwordField"
                               promptText="Masukkan password"
                               styleClass="form-control" />
            </VBox>

            <VBox alignment="CENTER">
    <Button text="Login"
            onAction="#handleLogin"
            styleClass="gradient-btn"
            minWidth="220"
            prefWidth="220"
            minHeight="48"
            prefHeight="48" />
</VBox>
        </VBox>

        <Label text="Belum punya akun?"
               styleClass="auth-links-text" />

        <Hyperlink text="Register sekarang"
                   onAction="#handleRegisterLink"
                   styleClass="auth-link" />

    </VBox>

</StackPane>