<?xml version="1.0" encoding="UTF-8"?>
<project name="Gymbrut-impl" default="default" basedir="..">
    <target name="default">
        <mkdir dir="${build.classes.dir}"/>
        <javac srcdir="${src.dir}" destdir="${build.classes.dir}" includeantruntime="false" source="${javac.source}" target="${javac.target}" classpath="${javac.classpath}" encoding="${source.encoding}"/>
        <mkdir dir="${dist.dir}"/>
        <jar destfile="${dist.jar}" basedir="${build.classes.dir}">
            <manifest>
                <attribute name="Main-Class" value="${main.class}"/>
            </manifest>
        </jar>
    </target>
</project>
